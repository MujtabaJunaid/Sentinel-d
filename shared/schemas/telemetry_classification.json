{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Telemetry Classification",
  "description": "SRE Agent output: telemetry analysis and three-way classification",
  "type": "object",
  "required": [
    "event_id",
    "status",
    "call_count_30d",
    "blast_radius",
    "kql_query_used",
    "confidence"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "status": {
      "type": "string",
      "enum": ["ACTIVE", "DORMANT", "DEFERRED"]
    },
    "call_count_30d": {
      "type": "integer",
      "minimum": 0
    },
    "last_called": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "blast_radius": {
      "type": "string",
      "enum": ["HIGH", "MEDIUM", "LOW", "UNKNOWN"]
    },
    "kql_query_used": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}
