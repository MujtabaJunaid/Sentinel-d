{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Historical Match",
  "description": "Result of Historical DB lookup for prior CVE resolutions",
  "type": "object",
  "required": [
    "event_id",
    "lookup_status",
    "match_confidence",
    "replay_eligible"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "lookup_status": {
      "type": "string",
      "enum": ["EXACT_MATCH", "SEMANTIC_MATCH", "NO_MATCH"]
    },
    "match_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "matched_cve_id": {
      "type": ["string", "null"]
    },
    "matched_record_id": {
      "type": ["string", "null"]
    },
    "recommended_strategy": {
      "type": ["string", "null"]
    },
    "historical_patch_diff": {
      "type": ["string", "null"]
    },
    "previous_outcome": {
      "type": ["string", "null"]
    },
    "solutions_tried_previously": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "strategy": { "type": "string" },
          "outcome": { "type": "string" },
          "failure_reason": { "type": ["string", "null"] }
        },
        "required": ["strategy", "outcome"]
      }
    },
    "replay_eligible": {
      "type": "boolean"
    },
    "replay_ineligible_reason": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false
}
