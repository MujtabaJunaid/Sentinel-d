{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Structured Context",
  "description": "DEV A OWNS THIS — NLP Pipeline output consumed by Patch Generator and Safety Governor",
  "type": "object",
  "required": [
    "event_id",
    "fix_strategy",
    "breaking_changes",
    "community_intent_class",
    "intent_confidence",
    "nvd_context",
    "migration_steps",
    "historical_match_status",
    "historical_patch_available",
    "solutions_to_avoid",
    "pipeline_version"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "fix_strategy": {
      "type": "string"
    },
    "breaking_changes": {
      "type": "array",
      "items": { "type": "object" }
    },
    "community_intent_class": {
      "type": "string"
    },
    "intent_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "nvd_context": {
      "type": "object"
    },
    "migration_steps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "historical_match_status": {
      "type": "string"
    },
    "historical_patch_available": {
      "type": "boolean"
    },
    "solutions_to_avoid": {
      "type": "array",
      "items": { "type": "object" }
    },
    "historical_record_id": {
      "type": ["string", "null"]
    },
    "pipeline_version": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
